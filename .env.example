# Use json for the bundled sample data, or supabase after applying the migration and seed.
GLOWFIT_CATALOG_SOURCE=json
GLOWFIT_CORS_ORIGINS=http://localhost:3000
GLOWFIT_CATALOG_CACHE_TTL_SECONDS=60
GLOWFIT_ENV=development
# Required in production. Comma-separated API hostnames, without a scheme.
GLOWFIT_TRUSTED_HOSTS=

# API server only. Never expose either key through NEXT_PUBLIC_* variables.
SUPABASE_URL=

# Recommended current server-side key from Settings > API Keys > Secret keys.
SUPABASE_SECRET_KEY=

# Optional legacy fallback from Settings > API Keys > Legacy API Keys.
SUPABASE_SERVICE_ROLE_KEY=
